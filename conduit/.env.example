# Copy to .env.local and fill in values. Never commit .env.local.

# ─── Required ──────────────────────────────────────────────────────────────────

# Backend API base URL (no trailing slash)
EXPO_PUBLIC_API_BASE_URL=https://api.conduit.app

# Phoenix relay WebSocket base URL
EXPO_PUBLIC_WS_BASE_URL=wss://relay.conduit.app

# ─── Smart account (Kernel v3) ─────────────────────────────────────────────────
# KernelFactory — deterministic CREATE2 deployment across all EVM chains (Kernel v3.1)
EXPO_PUBLIC_KERNEL_FACTORY_ADDRESS=0x6723b44Abeec4E71eBE3232BD5B455805baDD22f

# WebAuthn (P-256 / secp256r1) validator plugin used by Kernel v3
EXPO_PUBLIC_WEBAUTHN_VALIDATOR_ADDRESS=0xD990393C670dCcE8b4d8F858FB98c9912dBFAa06

# ─── TLS certificate pinning ───────────────────────────────────────────────────
# SHA-256 of the DER-encoded SubjectPublicKeyInfo of the TLS leaf cert.
# Generate: openssl s_client -connect api.conduit.app:443 </dev/null \
#   | openssl x509 -pubkey -noout \
#   | openssl pkey -pubin -outform DER \
#   | openssl dgst -sha256 -binary | base64
EXPO_PUBLIC_TLS_PIN_API=REPLACE_WITH_BASE64_SHA256_OF_API_CERT_PUBKEY
EXPO_PUBLIC_TLS_PIN_RELAY=REPLACE_WITH_BASE64_SHA256_OF_RELAY_CERT_PUBKEY

# ─── Backend-only (never in EXPO_PUBLIC_*) ─────────────────────────────────────
# These belong in the API gateway's .env, not the mobile app.

# Base RPC endpoint — used by the paymaster/bundler service
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# 0x Swap API v2 key — proxied server-side, never sent to the client
ZEROX_API_KEY=your_0x_api_key_here

# Pimlico bundler + paymaster API key
PIMLICO_API_KEY=your_pimlico_key_here
