# Copy to .env.local and fill in values. Never commit .env.local.

# Backend API base URL (REST + WebSocket relay)
EXPO_PUBLIC_API_BASE_URL=https://api.conduit.app
EXPO_PUBLIC_WS_BASE_URL=wss://relay.conduit.app

# Base RPC (private endpoint — keep server-side only, not in EXPO_PUBLIC_*)
# Used by the backend paymaster/bundler service, not the mobile client directly.
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# 0x Swap API key (proxied through the backend — never exposed to the client)
ZEROX_API_KEY=your_0x_api_key_here

# Pimlico bundler + paymaster
PIMLICO_API_KEY=your_pimlico_key_here
