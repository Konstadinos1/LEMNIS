# ─── Conduit Relay (Elixir/Phoenix) — required environment variables ──────────
# Copy to .env and fill in values. Never commit .env.
# In production these are injected by the container orchestrator (Fly/k8s).

# ─── Required (production) ─────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgres://conduit:password@localhost:5432/conduit_relay

# Redis connection URL (used for Pub/Sub fan-out across relay nodes)
REDIS_URL=redis://localhost:6379/0

# Phoenix secret key base — used for cookie signing / CSRF tokens
# Generate: mix phx.gen.secret
SECRET_KEY_BASE=REPLACE_WITH_64_RANDOM_BYTE_HEX_STRING

# JWT_SECRET must match the API gateway's JWT_SECRET
# (relay verifies the same HMAC-SHA256 API session JWTs)
JWT_SECRET=REPLACE_WITH_32_RANDOM_BYTES_HEX

# Public hostname for the relay WebSocket endpoint
RELAY_HOST=relay.conduit.app

# ─── Optional ──────────────────────────────────────────────────────────────────

# HTTP port (default 4000)
PORT=4000

# Ecto connection pool size (default 10)
POOL_SIZE=10
