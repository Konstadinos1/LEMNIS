# Copy to .env and fill in values. Never commit .env.

# Postgres
DATABASE_URL=postgres://conduit:conduit@localhost:5432/conduit_relay

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=changeme_at_least_32_chars
SECRET_KEY_BASE=changeme_at_least_64_chars

# 0x Swap API (server-side only — never sent to client)
ZEROX_API_KEY=your_0x_key

# Pimlico bundler + paymaster
PIMLICO_API_KEY=your_pimlico_key

# Paymaster signer (HSM-backed in production)
PAYMASTER_SIGNER_KEY=0x...

# Chain indexer
INDEXER_BASE_URL=http://localhost:4001
