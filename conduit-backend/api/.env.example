# ─── Conduit API Gateway — required environment variables ─────────────────────
# Copy to .env and fill in values. Never commit .env.

# ─── Required ──────────────────────────────────────────────────────────────────

# HMAC secret for signing API session JWTs (min 32 random bytes, hex-encoded)
# Generate: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_32_RANDOM_BYTES_HEX

# PostgreSQL connection string (used for sponsorship_log rate-limit table)
DATABASE_URL=postgres://conduit:password@localhost:5432/conduit_api

# 0x Swap API v2 key — obtain at https://dashboard.0x.org/
ZEROX_API_KEY=your_0x_api_key_here

# Pimlico bundler + paymaster API key — obtain at https://dashboard.pimlico.io/
PIMLICO_API_KEY=your_pimlico_api_key_here

# Relay internal HTTP base URL (Phoenix endpoint; must be RFC-1918 reachable)
RELAY_INTERNAL_URL=http://relay:4000

# ─── Optional ──────────────────────────────────────────────────────────────────

# Base RPC endpoint — defaults to public Base RPC if unset (rate-limited)
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Daily gas cap per account (in gas units; default 50_000_000 ≈ $0.50 on Base)
DAILY_GAS_LIMIT=50000000

# Fastify server port
PORT=3000

# Log level (trace | debug | info | warn | error | fatal)
LOG_LEVEL=info

# CORS allowed origin (omit or set to 'false' to disable CORS)
CORS_ORIGIN=false

# Firebase Admin SDK service account JSON (base64-encoded) for push notifications
FIREBASE_SERVICE_ACCOUNT_B64=

# APNs team ID + key ID + private key (p8 format, base64-encoded) for iOS push
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_PRIVATE_KEY_B64=
